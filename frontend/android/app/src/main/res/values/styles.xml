<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting when the OS's Dark Mode setting is off -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Show a splash screen on the activity. Automatically removed when
             the Flutter engine draws its first frame -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Theme applied to the Android Window as soon as the process has started.
         This theme determines the color of the Android Window while your
         Flutter UI initializes, as well as behind your Flutter UI while its
         running.

         This Theme is only used starting with V2 of Flutter's Android embedding. -->
    <!-- v21.1.1 — parent passé de Theme.MaterialComponents à un thème Android
         stock après la purge flutter_stripe (qui apportait la dep transitive
         com.google.android.material:material). Flutter rend lui-même ses
         widgets Material, on n'a besoin que d'un Window propre. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- v23.1 part 25 — CRITICAL FIX du carré gris persistant à Accueil.
             ?android:colorBackground est un attribut système qui sur Samsung
             One UI light mode défaut à #FAFAFA (gris). Ce gris transparaît
             par tout pixel transparent de Flutter (safe areas, gesture zone,
             écran de transition). On force WHITE explicitement, et on
             override ALSO android:colorBackground au cas où d'autres widgets
             du système y font référence. -->
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:colorBackground">@android:color/white</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- v23.1 part 26 — Option B (Daniel) : navigationBar NOIRE classique
             Android. Évite le rectangle blanc qui dépassait dans le coin
             bas-gauche du système. -->
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>
</resources>
