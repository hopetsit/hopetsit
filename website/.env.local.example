# Copy to .env.local to override defaults.
NEXT_PUBLIC_API_BASE=https://hopetsit-backend.onrender.com/api/v1

# ─── Firebase Web (Google sign-in) ───────────────────────────────────────────
# Copy from Firebase Console → Project Settings → General → Your apps → Web.
# Same Firebase project as the mobile app — just register a new "Web" app
# inside it and paste the config below.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
