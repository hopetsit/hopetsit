# Cloudinary (media storage)
CLOUDINARY_CLOUD_NAME=<YOUR_CLOUDINARY_CLOUD_NAME>
CLOUDINARY_API_KEY=<YOUR_CLOUDINARY_API_KEY>
CLOUDINARY_API_SECRET=<YOUR_CLOUDINARY_API_SECRET>

# Firebase Admin SDK (FCM push notifications)
FIREBASE_PROJECT_ID=<YOUR_FIREBASE_PROJECT_ID>
FIREBASE_CLIENT_EMAIL=<YOUR_FIREBASE_SERVICE_ACCOUNT_EMAIL>
FIREBASE_PRIVATE_KEY="<YOUR_FIREBASE_PRIVATE_KEY_WITH_\n_ESCAPED>"
FIREBASE_API_KEY=<YOUR_FIREBASE_WEB_API_KEY>

# Auth
JWT_SECRET=<GENERATE_64_CHAR_RANDOM_STRING>

# AES-256-GCM encryption key for IBAN, PayPal email, card number, CVC
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64_HEX_CHARS>

# Admin seed (used only by src/scripts/seedAdmin.js to create the first admin)
ADMIN_SEED_EMAIL=<ADMIN_EMAIL>
ADMIN_SEED_PASSWORD=<STRONG_PASSWORD>

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>

# Runtime
NODE_ENV=development
PORT=5000

# CORS (comma-separated list of allowed origins — see sprint1/step2)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# SMTP (transactional emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<YOUR_SMTP_USER>
SMTP_PASS=<YOUR_SMTP_APP_PASSWORD>
SMTP_FROM="HopeTSIT <no-reply@example.com>"

# Stripe
STRIPE_SECRET_KEY=sk_test_<YOUR_STRIPE_SECRET_KEY>
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_STRIPE_WEBHOOK_SECRET>
Stripe_publish_key=pk_test_<YOUR_STRIPE_PUBLISHABLE_KEY>
STRIPE_CONNECT_REFRESH_URL=http://localhost:5000/stripe-connect/refresh
STRIPE_CONNECT_RETURN_URL=http://localhost:5000/stripe-connect/return

# Translation provider for post auto-translation. One of: none, deepl, google.
# When 'none', the service returns "[auto] <text>" as a placeholder.
TRANSLATION_API_PROVIDER=none

# Sprint 5 step 4 — current T&C version. Stored on accept-terms for auditability.
TERMS_VERSION=v1.0

# Sprint 7 step 5 — email address that receives review-flagged alerts (3+ reports).
ADMIN_ALERT_EMAIL=<alerts@hopetsit.com>

# Sprint 8 step 4 — required in production to access /api-docs.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SWAGGER_AUTH_TOKEN=<GENERATE_HEX_TOKEN>

# Sprint 8 step 5 — pino log level (trace|debug|info|warn|error|fatal).
LOG_LEVEL=info

# Sprint 8 step 6 — optional Sentry error tracking (opt-in).
# Leave empty to disable. Get your DSN at https://sentry.io/
SENTRY_DSN_BACKEND=
SENTRY_TRACES_SAMPLE_RATE=0
# DEEPL_API_KEY=
# GOOGLE_TRANSLATE_API_KEY=

# PayPal (deprecated v20.1 — being removed in Airwallex migration)
# PAYPAL_CLIENT_ID=<YOUR_PAYPAL_CLIENT_ID>
# PAYPAL_CLIENT_SECRET=<YOUR_PAYPAL_CLIENT_SECRET>
# PAYPAL_MODE=sandbox

# ─── Airwallex (v20.1 — replacing Stripe) ──────────────────────────────────
# Get these at Airwallex Dashboard → Settings → Developer → API Keys.
# Use the LIVE keys for production (we don't have a Demo environment yet).
AIRWALLEX_CLIENT_ID=<YOUR_AIRWALLEX_CLIENT_ID>
AIRWALLEX_API_KEY=<YOUR_AIRWALLEX_API_KEY>
# Demo: https://api-demo.airwallex.com   Live: https://api.airwallex.com
AIRWALLEX_BASE_URL=https://api.airwallex.com
# Webhook signing secret (set when creating the webhook endpoint in Airwallex
# dashboard → Developer → Webhooks). Used by airwallexWebhookController to
# verify event authenticity.
AIRWALLEX_WEBHOOK_SECRET=<YOUR_AIRWALLEX_WEBHOOK_SECRET>

# Payment provider switch. Controls which provider donations / boost /
# premium / map-boost / bookings use:
#   'stripe'    (default) — historical Stripe flows, intact
#   'airwallex'           — new Airwallex flows (mobile app must use AWX SDK)
# During the migration window, leave on 'stripe' until the mobile app ships
# with the Airwallex Flutter SDK.
PAYMENT_PROVIDER=stripe
